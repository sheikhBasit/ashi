#!/usr/bin/env bash
set -euo pipefail

# ashi -- CLI wrapper for the ASHI AI OS daemon
# Install: sudo ln -sf /home/basitdev/workspace/ashi/scripts/ashi /usr/local/bin/ashi

ASHI_URL="${ASHI_URL:-http://127.0.0.1:7070}"
DAEMON_LOG="$HOME/SecondBrain/AI/agent-logs/daemon.log"

_require_curl() {
    if ! command -v curl &>/dev/null; then
        echo "ERROR: curl is required" >&2
        exit 1
    fi
}

_check_daemon() {
    if ! curl -sf "$ASHI_URL/health" &>/dev/null; then
        echo "ERROR: ASHI daemon not reachable at $ASHI_URL" >&2
        echo "Start it: systemctl --user start ashi" >&2
        exit 1
    fi
}

cmd_run() {
    _require_curl
    _check_daemon

    local goal="$*"
    if [ -z "$goal" ]; then
        echo "Usage: ashi run <goal>" >&2
        exit 1
    fi

    # Build JSON payload
    local payload
    payload=$(python3 -c "import json; print(json.dumps({'goal': '''$goal''', 'max_steps': 10, 'require_confirmation': True}))" 2>/dev/null || \
              printf '{"goal":"%s","max_steps":10,"require_confirmation":true}' "$goal")

    echo "Starting agent run..."
    local response
    response=$(curl -sf -X POST "$ASHI_URL/agent/run" \
        -H "Content-Type: application/json" \
        -d "$payload")

    local tcu_id
    tcu_id=$(echo "$response" | python3 -c "import sys,json; print(json.load(sys.stdin)['tcu_id'])" 2>/dev/null || echo "")

    if [ -z "$tcu_id" ]; then
        echo "Failed to start run. Response: $response"
        exit 1
    fi

    echo "Run started: tcu_id=$tcu_id"
    echo "Polling status..."

    # Poll until done
    local status="running"
    while [ "$status" = "running" ]; do
        sleep 2
        local status_resp
        status_resp=$(curl -sf "$ASHI_URL/agent/status/$tcu_id" 2>/dev/null || echo '{"status":"unknown"}')
        status=$(echo "$status_resp" | python3 -c "import sys,json; print(json.load(sys.stdin).get('status','unknown'))" 2>/dev/null || echo "unknown")
        local steps
        steps=$(echo "$status_resp" | python3 -c "import sys,json; d=json.load(sys.stdin); print(f\"{d.get('steps_completed',0)}/{d.get('steps_total',0)}\")" 2>/dev/null || echo "?/?")
        echo "  status=$status steps=$steps"
    done

    # Final result
    echo ""
    echo "=== Result ==="
    curl -sf "$ASHI_URL/agent/status/$tcu_id" | python3 -m json.tool 2>/dev/null || \
        curl -sf "$ASHI_URL/agent/status/$tcu_id"
}

cmd_status() {
    _require_curl
    _check_daemon

    local tcu_id="${1:-}"
    if [ -z "$tcu_id" ]; then
        echo "Usage: ashi status <tcu_id>" >&2
        exit 1
    fi

    curl -sf "$ASHI_URL/agent/status/$tcu_id" | python3 -m json.tool 2>/dev/null || {
        echo "Run $tcu_id not found or daemon unreachable."
        exit 1
    }
}

cmd_tools() {
    _require_curl
    _check_daemon
    curl -sf "$ASHI_URL/tools" | python3 -m json.tool 2>/dev/null || \
        curl -sf "$ASHI_URL/tools"
}

cmd_health() {
    _require_curl
    curl -sf "$ASHI_URL/health" | python3 -m json.tool 2>/dev/null || {
        echo "ASHI daemon not reachable at $ASHI_URL"
        exit 1
    }
}

cmd_logs() {
    if [ -f "$DAEMON_LOG" ]; then
        tail -f "$DAEMON_LOG"
    else
        echo "Log file not found: $DAEMON_LOG"
        echo "Falling back to journalctl..."
        journalctl --user -u ashi -f --no-pager
    fi
}

cmd_restart() {
    echo "Restarting ASHI daemon..."
    systemctl --user restart ashi
    sleep 2
    systemctl --user status ashi --no-pager || true
}

cmd_help() {
    cat <<'EOF'
ashi -- ASHI AI OS CLI

Usage:
  ashi run <goal>        Run an agent with a goal
  ashi status <tcu_id>   Check status of an agent run
  ashi tools             List all registered tools
  ashi health            Daemon health check
  ashi logs              Tail the daemon log
  ashi restart           Restart the systemd service
  ashi help              Show this help

Environment:
  ASHI_URL   Override daemon URL (default: http://127.0.0.1:7070)
EOF
}

# Route subcommand
case "${1:-help}" in
    run)     shift; cmd_run "$@" ;;
    status)  shift; cmd_status "$@" ;;
    tools)   cmd_tools ;;
    health)  cmd_health ;;
    logs)    cmd_logs ;;
    restart) cmd_restart ;;
    help|--help|-h) cmd_help ;;
    *)
        echo "Unknown command: $1" >&2
        cmd_help
        exit 1
        ;;
esac
